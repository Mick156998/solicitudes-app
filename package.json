{
  "name": "solicitudes-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mock-api": "json-server --watch db.json --port 3001",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "mock-api:e2e": "json-server --watch db.test.json --port 3001",
    "test:e2e": "concurrently \"npm run dev\" \"npm run mock-api\" \"wait-on http://localhost:3000 && wait-on http://localhost:3001 && playwright test\"",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "dotenv-flow": "^4.1.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "json-server": "^1.0.0-beta.15",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
